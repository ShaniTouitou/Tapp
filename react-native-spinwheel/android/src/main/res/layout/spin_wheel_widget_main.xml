<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Background fills the entire widget (shown once assets are ready) -->
    <ImageView
        android:id="@+id/widget_background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop" />

    <!-- Wheel stack: wheel + frame overlay + spin button, centered -->
    <FrameLayout
        android:id="@+id/widget_wheel_container"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_gravity="center">

        <!-- Wheel image — rotation is set via RemoteViews.setFloat("setRotation") -->
        <ImageView
            android:id="@+id/widget_wheel"
            android:layout_width="190dp"
            android:layout_height="190dp"
            android:layout_gravity="center"
            android:scaleType="fitCenter" />

        <!-- Frame overlay — static, sits on top of wheel -->
        <ImageView
            android:id="@+id/widget_frame"
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_gravity="center"
            android:scaleType="fitCenter" />

        <!-- Spin button — tappable, centered on top of frame -->
        <ImageView
            android:id="@+id/widget_spin_button"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="center"
            android:scaleType="fitCenter" />

    </FrameLayout>

    <!-- Loading overlay — shown while assets are downloading on first launch.
         Colors match the app: white/lavender gradient + #7B4FBF purple accent. -->
    <FrameLayout
        android:id="@+id/widget_loading_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/widget_loading_bg"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <!-- Purple spinner -->
            <ProgressBar
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:indeterminate="true"
                android:indeterminateTint="#7B4FBF"
                android:layout_marginBottom="16dp" />

            <!-- App title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SPIN WHEEL"
                android:textColor="#7B4FBF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <!-- Tagline: centered, bold, larger, two lines -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✨ Your lucky moment&#10;is almost here! ✨"
                android:textColor="#7B4FBF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:gravity="center"
                android:lineSpacingMultiplier="1.3" />

        </LinearLayout>

    </FrameLayout>

</FrameLayout>
